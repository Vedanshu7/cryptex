# Copy to .env and fill in values before starting the stack.
# Never commit .env to source control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Exchange (use testnet keys for local development) ─────────────────────────
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here
BINANCE_BASE_URL=https://testnet.binance.vision

# ── Trading symbols ───────────────────────────────────────────────────────────
TRADE_SYMBOLS=btcusdt,ethusdt

# ── Signal pipeline settings ──────────────────────────────────────────────────
CANDLE_TIMEFRAME_MINUTES=5
SIGNAL_TTL_SECONDS=90
SIGNAL_MIN_CONFIDENCE=0.7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Signal generator ──────────────────────────────────────────────────────────
SIGNAL_INTERVAL_SECONDS=300

# ── LLM signal source (optional) ──────────────────────────────────────────────
# Set SIGNAL_SOURCE=llm or SIGNAL_SOURCE=both to enable LLM-based signals.
# When 'both', ML signals run every SIGNAL_INTERVAL_SECONDS and LLM signals
# run every LLM_SIGNAL_INTERVAL_SECONDS (slower — manage API cost).
SIGNAL_SOURCE=ml

# LLM provider: 'anthropic' (default) or 'openai'
LLM_PROVIDER=anthropic

# API keys — leave blank to disable LLM source gracefully (no crash)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Override the default model for the chosen provider
# LLM_MODEL=claude-3-5-haiku-20241022

# LLM prediction cadence in seconds (default 900 = 15 min to keep API cost low)
LLM_SIGNAL_INTERVAL_SECONDS=900

# Number of candles included in the LLM prompt (controls token usage)
LLM_CANDLE_WINDOW=20
