# Copy to .env and fill in values before starting the stack.
# Never commit .env to source control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Exchange (use testnet keys for local development) ─────────────────────────
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here
BINANCE_BASE_URL=https://testnet.binance.vision

# ── Trading symbols ───────────────────────────────────────────────────────────
TRADE_SYMBOLS=btcusdt,ethusdt

# ── Signal pipeline settings ──────────────────────────────────────────────────
CANDLE_TIMEFRAME_MINUTES=5
SIGNAL_TTL_SECONDS=90
SIGNAL_MIN_CONFIDENCE=0.7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Signal generator ──────────────────────────────────────────────────────────
SIGNAL_INTERVAL_SECONDS=300
