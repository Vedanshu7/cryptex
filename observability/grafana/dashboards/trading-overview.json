{
  "title": "Trading Platform Overview",
  "uid": "trading-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Orders Placed (per minute)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(trading_orders_total[1m]) * 60",
          "legendFormat": "orders/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "Order Fill Rate (%)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(trading_orders_total{status='FILLED'}[5m]) / rate(trading_orders_total[5m]) * 100",
          "legendFormat": "fill rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent" }
      }
    },
    {
      "id": 3,
      "title": "Order Placement Latency (P50 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(trading_order_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, rate(trading_order_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tick Ingestion Rate (by symbol)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(exchange_connector_ticks_total[1m])",
          "legendFormat": "{{ symbol }}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Signal Confidence Distribution",
      "type": "histogram",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "signal_pipeline_signal_confidence_bucket",
          "legendFormat": "confidence"
        }
      ]
    },
    {
      "id": 6,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    }
  ]
}
